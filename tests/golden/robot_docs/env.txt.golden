env:
  CODING_AGENT_SEARCH_NO_UPDATE_PROMPT=1   skip update prompt
  TUI_HEADLESS=1                           skip update prompt
  CASS_DATA_DIR                            override data dir
  CASS_DB_PATH                             override db path
  CASS_OUTPUT_FORMAT=json|jsonl|compact|sessions|toon  default structured output
  CASS_SEARCH_TIMEOUT_MS=<N>               default `cass search`/`pack` timeout in ms (--timeout overrides; 0=none)
  CASS_SEARCH_LIMIT=<N>                    default search/pack limit (--limit overrides; 0=no limit)
  CASS_SEARCH_MODE=lexical|semantic|hybrid default search/pack mode (--mode overrides)
  TOON_DEFAULT_FORMAT=toon|json            fallback structured output for all tools
  TOON_INDENT=<N>                           pretty-print TOON with indent
  TOON_KEY_FOLDING=off|safe                 TOON key folding mode
  CASS_NO_COLOR                            force monochrome
  CASS_RESPECT_NO_COLOR=1                  honor global NO_COLOR
  CASS_TRACE_FILE                          default trace path
  CASS_INDEX_NO_PROGRESS_EVENTS=1          suppress NDJSON events from `cass index --json`
  CASS_RESPONSIVENESS_DISABLE=1            pin indexer fan-out at 100% (skip governor)
  CASS_RESPONSIVENESS_MIN_CAPACITY_PCT=<N> floor for governor shrink (default 25, range 10..100)
  CASS_RESPONSIVENESS_MAX_LOAD_PER_CORE=<F>  loadavg/core threshold for step-down (default 1.25)
  CASS_RESPONSIVENESS_SEVERE_LOAD_PER_CORE=<F>  loadavg/core threshold for floor drop (default 1.75)
  CASS_RESPONSIVENESS_MAX_PSI_AVG10=<F>    /proc/pressure/cpu some-avg10 step-down (default 20.0)
  CASS_RESPONSIVENESS_SEVERE_PSI_AVG10=<F>  PSI severe threshold (default 40.0)
  CASS_RESPONSIVENESS_GROWTH_TICKS=<N>     healthy ticks needed before each 25pp grow step (default 3)
  CASS_RESPONSIVENESS_TICK_SECS=<N>        sampler interval in seconds (default 2)
  CASS_RESPONSIVENESS_CALIBRATION=static|conformal  threshold policy (DEFAULT: conformal). Set to `static` to revert to legacy hand-tuned 1.25/20.0 thresholds.
  CASS_RESPONSIVENESS_CONFORMAL_K=<N>      calibration window size (clamped 16..4096, default 256)
  CASS_RESPONSIVENESS_CONFORMAL_K_MIN=<N>  min samples before quantile emits (clamped 4..K, default 32)
  CASS_RESPONSIVENESS_CONFORMAL_ALPHA_PRESSURED=<F>  FP rate for pressured quantile (0<α<0.5, default 0.05)
  CASS_RESPONSIVENESS_CONFORMAL_ALPHA_SEVERE=<F>  FP rate for severe quantile (0<α<pressured, default 0.01)
  CASS_RESPONSIVENESS_DRIFT_DELTA=<F>      Page-Hinkley drift tolerance δ (default 0.01)
  CASS_RESPONSIVENESS_DRIFT_LAMBDA=<F>     Page-Hinkley trigger λ for calibration reset (default 0.5)
  CASS_STREAMING_CONSUMER_COMMIT_SECS=<N>  base streaming-consumer Tantivy commit cadence (default 5)
  CASS_SEMANTIC_BATCH_SIZE=<N>             embedder batch size (default 128)
  CASS_SEMANTIC_PREP_PARALLEL=1            opt in to rayon-parallel canonicalize+hash prep (default off: serial is measurably faster on the common cheap-embedder path)
  CASS_SEMANTIC_EMBED_BATCH_WARN_AFTER_MS=30000  warn when one embedder batch exceeds the cass#257-derived 30s healthy-run threshold
  CASS_SEMANTIC_EMBED_BATCH_FAIL_AFTER_MS=300000  abort after a returned embedder batch exceeds the cass#257-derived 5m watchdog threshold; 0 disables
  CASS_SEMANTIC_MAX_MESSAGES_PER_CHECKPOINT=10000 cap models backfill checkpoints at whole-conversation prefixes near 10k selected messages; 0 disables
  CASS_SEMANTIC_MAX_BYTES_PER_CHECKPOINT=8388608 cap models backfill checkpoints at whole-conversation prefixes near 8MiB selected content; 0 disables
  CASS_STREAMING_CONSUMER_COMBINE=0        DISABLE flat-combining drain in run_streaming_consumer (Card 3; DEFAULT: on). Any non-off value (unset, 1, true, yes, on) leaves combining enabled.
  CASS_STREAMING_COMBINE_MAX=<N>           max messages per combined drain (clamped 1..1024, default 64)
  CASS_STREAMING_COMBINE_MAX_BYTES=<N>     byte cap per combined drain (clamped 1MiB..STREAMING_MAX, default half)
  CASS_INDEXER_PARALLEL_WAL=off            DISABLE Card 1 parallel-WAL shadow observer (DEFAULT: shadow). Observer records per-chunk wall-clock; does NOT change commit semantics. `on`/`commit` are reserved for a future revision.
