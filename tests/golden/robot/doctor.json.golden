        ],
        "refuses_when": [
          "support-bundle-is-redacted-diagnostic-evidence"
        ],
        "decision_when_valid": "refused",
        "notes": "Support bundles are for diagnostics and sharing; they must not become repair authorities."
      }
    ],
    "notes": [
      "Doctor chooses the most conservative authority first; live sources never outrank an existing archive when coverage shrinks.",
      "Candidate-only means evidence may seed an isolated rebuild candidate, not direct promotion.",
      "Promotion requires a later non-decreasing coverage check plus checksum-verified receipt."
    ]
