        {
          "name": "force-rebuild",
          "description": "Request a derived rebuild; never bypasses archive coverage gates or plan fingerprints",
          "arg_type": "flag",
          "required": false,
          "enum_values": [
            "true",
            "false"
          ]
        },
        {
          "name": "allow-repeated-repair",
          "description": "Permit a mutating repair even when a previous failure marker exists",
          "arg_type": "flag",
          "required": false,
          "enum_values": [
            "true",
            "false"
          ]
        },
        {
          "name": "recover-from-archive",
          "description": "Rebuild the source JSONL tree from the canonical archive's preserved `extra_json`/`extra_bin` events into `<DIR>`, so a corrupt archive can be re-ingested from cass's own data with `cass index --full` (no stock-sqlite `.recover` needed). Opens the archive read-only",
          "arg_type": "option",
          "value_type": "path",
          "required": false
        },
        {
          "name": "rebuild-canonical-fts",
          "description": "Drop and rebuild the canonical FTS5 shadow tables in place. Use when the canonical messages/conversations rows are intact but a derived FTS5 structure (e.g. fts_messages_docsize) is corrupt. Requires `--yes`; never modifies canonical rows",
          "arg_type": "flag",
          "required": false,
          "default": "false",
          "enum_values": [
            "true",
            "false"
          ]
        },
        {
          "name": "cleanup-interrupted-artifacts",
          "description": "Quarantine interrupted `raw_mirror_capture` staging artifacts that block doctor mutation, instead of forcing a manual `rm` inside the data dir. Requires `--yes`; artifacts are renamed into a quarantine dir, never deleted",
          "arg_type": "flag",
          "required": false,
          "default": "false",
          "enum_values": [
            "true",
            "false"
          ]
        },
        {
          "name": "robot-format",
          "description": "Output format for robot mode (overrides --json when specified)",
          "arg_type": "option",
          "value_type": "enum",
          "required": false,
          "enum_values": [
            "json",
            "jsonl",
            "compact",
            "sessions",
            "toon"
          ]
        }
