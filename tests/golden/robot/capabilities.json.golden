  "exit_codes": [
    {
      "code": "0",
      "meaning": "success",
      "retryable": "no",
      "agent_action": "Read stdout as the command result."
    },
    {
      "code": "1",
      "meaning": "health check failed",
      "retryable": "yes",
      "agent_action": "Inspect JSON recommended_action before retrying or indexing."
    },
    {
      "code": "2",
      "meaning": "usage or parsing error",
      "retryable": "no",
      "agent_action": "Fix argv syntax; follow the JSON err.hint or examples."
    },
    {
      "code": "3",
      "meaning": "index or database missing",
      "retryable": "yes",
      "agent_action": "Run cass index --full when health/status recommends it."
    },
    {
      "code": "4",
      "meaning": "network error",
      "retryable": "yes",
      "agent_action": "Check connectivity or remote source configuration, then retry."
    },
    {
      "code": "5",
      "meaning": "data corruption",
      "retryable": "depends",
      "agent_action": "Inspect health/status/doctor JSON and rebuild only derived assets when recommended."
    },
    {
      "code": "6",
      "meaning": "incompatible version",
      "retryable": "no",
      "agent_action": "Upgrade cass or the calling client before retrying."
    },
    {
      "code": "7",
      "meaning": "lock or busy",
      "retryable": "yes",
      "agent_action": "Retry later with bounded backoff; another cass operation owns the lock."
    },
    {
      "code": "8",
      "meaning": "partial result",
      "retryable": "yes",
      "agent_action": "Increase timeout or page through remaining results."
    },
    {
      "code": "9",
      "meaning": "unknown error",
      "retryable": "maybe",
      "agent_action": "Read err.kind, err.message, and trace output before deciding."
    },
    {
      "code": "10",
      "meaning": "config or timeout",
      "retryable": "depends",
      "agent_action": "Branch on JSON err.kind; numeric code 10 is intentionally domain-specific."
    },
    {
      "code": "11",
      "meaning": "config validation",
      "retryable": "no",
      "agent_action": "Fix the reported configuration field before retrying."
    },
    {
      "code": "12",
      "meaning": "source or SSH problem",
      "retryable": "maybe",
      "agent_action": "Inspect source JSON fields and verify the remote host or path."
    },
    {
      "code": "13",
      "meaning": "mapping or not-found",
      "retryable": "depends",
      "agent_action": "Branch on err.kind and verify the requested source/session mapping."
    },
    {
      "code": "14",
      "meaning": "I/O or mapping",
      "retryable": "maybe",
      "agent_action": "Inspect err.kind and path details; retry only after the path is reachable."
    },
    {
      "code": "15",
      "meaning": "semantic or embedder unavailable",
      "retryable": "yes",
      "agent_action": "Install/verify models or continue with lexical fallback when acceptable."
    },
    {
      "code": "20-21",
      "meaning": "model acquisition failure",
      "retryable": "maybe",
      "agent_action": "Check err.kind and err.hint; retry download or use --from-file."
    },
    {
      "code": "22",
      "meaning": "I/O during model handling",
      "retryable": "maybe",
      "agent_action": "Verify model cache permissions and available disk before retrying."
    },
    {
      "code": "23",
      "meaning": "download failure",
      "retryable": "yes",
      "agent_action": "Retry with network available or install from a local model directory."
    },
    {
      "code": "24",
      "meaning": "I/O during model verify/install",
      "retryable": "maybe",
      "agent_action": "Fix filesystem permissions or disk space, then retry."
    }
  ],
  "env_vars": [
    {
      "name": "CODING_AGENT_SEARCH_NO_UPDATE_PROMPT",
      "default": "0",
      "description": "Set to 1 to skip update prompts in automation."
    },
    {
      "name": "TUI_HEADLESS",
      "default": "0",
      "description": "Set to 1 for headless test runs and prompt-free TUI behavior."
    },
    {
      "name": "CASS_DATA_DIR",
      "description": "Override the cass data directory."
    },
    {
      "name": "CASS_DB_PATH",
      "description": "Override the SQLite database path."
    },
    {
      "name": "CASS_OUTPUT_FORMAT",
      "description": "Default structured output format: json, jsonl, compact, sessions, or toon."
    },
    {
      "name": "TOON_DEFAULT_FORMAT",
      "description": "Fallback structured output format for tools that support TOON."
    },
    {
      "name": "TOON_INDENT",
      "description": "Pretty-print TOON output with the requested indentation."
    },
    {
      "name": "TOON_KEY_FOLDING",
      "default": "safe",
      "description": "Controls TOON key folding: off or safe."
    },
    {
      "name": "CASS_NO_COLOR",
      "description": "Force monochrome output."
    },
    {
      "name": "CASS_RESPECT_NO_COLOR",
      "default": "0",
      "description": "Set to 1 to honor the global NO_COLOR convention."
    },
    {
      "name": "NO_COLOR",
      "description": "Global no-color convention when respected."
    },
    {
      "name": "CASS_TRACE_FILE",
      "description": "Default JSONL trace path for command execution spans."
    },
    {
      "name": "CASS_INDEX_NO_PROGRESS_EVENTS",
      "default": "0",
      "description": "Suppress NDJSON progress events from cass index --json when set to 1."
    },
    {
      "name": "CASS_SEMANTIC_EMBEDDER",
      "description": "Select the semantic embedder/model implementation when configured."
    },
    {
      "name": "CASS_SEMANTIC_BATCH_SIZE",
      "default": "128",
      "description": "Batch size for semantic embedding work."
    },
    {
      "name": "CASS_SEMANTIC_EMBED_BATCH_WARN_AFTER_MS",
      "default": "30000",
      "description": "Warn when one semantic embedder batch exceeds the cass#257-derived 30s healthy-run threshold."
    },
    {
      "name": "CASS_SEMANTIC_EMBED_BATCH_FAIL_AFTER_MS",
      "default": "300000",
      "description": "Abort after a returned semantic embedder batch exceeds the cass#257-derived 5m watchdog threshold; 0 disables."
    },
    {
      "name": "CASS_SEMANTIC_MAX_MESSAGES_PER_CHECKPOINT",
      "default": "10000",
      "description": "Soft cap for cass models backfill checkpoints at whole-conversation prefixes near 10k selected messages; 0 disables."
    },
    {
      "name": "CASS_SEMANTIC_MAX_BYTES_PER_CHECKPOINT",
      "default": "8388608",
      "description": "Soft cap for cass models backfill checkpoints at whole-conversation prefixes near 8MiB selected content; 0 disables."
    },
    {
      "name": "CASS_RESPONSIVENESS_DISABLE",
      "default": "0",
      "description": "Set to 1 to disable the indexer responsiveness governor."
    },
    {
      "name": "CASS_RESPONSIVENESS_CALIBRATION",
      "default": "conformal",
      "description": "Responsiveness-governor threshold policy: conformal or static."
    },
    {
      "name": "CASS_STREAMING_CONSUMER_COMMIT_SECS",
      "default": "5",
      "description": "Base Tantivy commit cadence for the streaming consumer."
    },
    {
      "name": "CASS_STREAMING_CONSUMER_COMBINE",
      "default": "1",
      "description": "Set to 0 to disable flat-combining drain in the streaming consumer."
    },
    {
      "name": "CASS_AIDER_DATA_ROOT",
      "description": "Override Aider session discovery root."
    },
    {
      "name": "PI_CODING_AGENT_DIR",
      "description": "Override Pi Agent session discovery root."
    },
    {
      "name": "CODEX_HOME",
      "description": "Override Codex session discovery root."
    },
    {
      "name": "GEMINI_HOME",
      "description": "Override Gemini session discovery root."
    },
    {
      "name": "OPENCODE_STORAGE_ROOT",
      "description": "Override OpenCode session discovery root."
    },
    {
      "name": "CHATGPT_ENCRYPTION_KEY",
      "description": "Provide the key used for encrypted ChatGPT conversation imports."
    },
    {
      "name": "CASS_DAEMON_SOCKET",
      "description": "Override the semantic daemon Unix socket path."
    }
  ],
  "workflows": [
    {
      "name": "cold-start",
      "intent": "Discover readiness, exact next command, docs, schemas, workflows, and recoveries from zero context.",
      "first_command": "cass triage --json",
      "follow_up_commands": [
        "cass capabilities --json",
        "cass --robot-help --color=never",
        "cass robot-docs guide --color=never",
        "cass introspect --json"
      ],
      "parse_contract": "Parse status, healthy, initialized, next_command, recommended_commands[], discovery, starter_workflows[], and mistake_recoveries[].",
      "note": "Use triage first when you do not know whether the archive is initialized; use capabilities/introspect for static API binding."
    },
    {
      "name": "api-discovery",
      "intent": "Discover the static CLI contract for typed clients and prompt construction.",
      "first_command": "cass capabilities --json",
      "follow_up_commands": [
        "cass introspect --json",
        "cass robot-docs commands --color=never",
        "cass robot-docs schemas --color=never"
      ],
      "parse_contract": "Parse workflows, commands, global_flags, exit_codes, env_vars, limits, and response_schemas.",
      "note": "Capabilities is static self-description; triage is the read-only runtime preflight."
    },
    {
      "name": "health-preflight",
      "intent": "Check whether search is ready before issuing queries.",
      "first_command": "cass health --json",
      "follow_up_commands": [
        "cass status --json",
        "cass index --full --json",
        "cass doctor --json"
      ],
      "parse_contract": "Branch on healthy, status, fallback_mode, and recommended_action.",
      "note": "Do not hand-delete index assets; index/doctor are the recovery surfaces."
    },
    {
      "name": "bounded-search",
      "intent": "Search sessions without flooding the caller's token budget.",
      "first_command": "cass search \"<query>\" --robot --limit 10 --fields summary --max-content-length 800 --robot-meta",
      "follow_up_commands": [
        "cass view <source_path> -n <line_number> --json",
        "cass expand <source_path> --line <line_number> -C 3 --json",
        "cass pack \"<query>\" --robot --max-tokens 4000 --limit 10"
      ],
      "parse_contract": "Parse hits[], _meta.realized_mode, _meta.fallback_mode, cursor, and *_truncated flags.",
      "note": "Prefer an explicit --limit in automation; limit 0 intentionally means unbounded."
    },
    {
      "name": "answer-pack",
      "intent": "Build a deterministic cited handoff bundle for another agent.",
      "first_command": "cass pack \"<question>\" --robot --max-tokens 4000 --max-evidence 8 --max-sessions 3 --require-evidence",
      "follow_up_commands": [
        "cass search \"<question>\" --robot --limit 10 --fields provenance --robot-meta",
        "cass view <source_path> -n <line_number> --json"
      ],
      "parse_contract": "Parse evidence[], warnings[], privacy, freshness, health, and omitted[].",
      "note": "Use pack when the downstream consumer needs citations rather than raw search hits."
    },
    {
      "name": "session-drilldown",
      "intent": "Move from a hit to surrounding conversation context.",
      "first_command": "cass view <source_path> -n <line_number> --json",
      "follow_up_commands": [
        "cass expand <source_path> --line <line_number> -C 5 --json",
        "cass context <source_path> --json",
        "cass resume <source_path> --shell"
      ],
      "parse_contract": "Parse path, line_number, message, surrounding messages, and resume command output.",
      "note": "Use source_path and line_number from search hits; do not infer file formats by hand."
    },
    {
      "name": "semantic-models",
      "intent": "Understand or repair semantic-search readiness.",
      "first_command": "cass models status --json",
      "follow_up_commands": [
        "cass models verify --json",
        "cass models install --model minilm",
        "cass models install --from-file <dir> --model minilm",
        "cass models backfill"
      ],
      "parse_contract": "Parse installed, available, cache_dir, verification status, and err.kind.",
      "note": "Models are opt-in; lexical fallback is valid while the model is absent."
    }
  ],
  "mistake_recoveries": [
    {
      "wrong": "cass searh \"query\" --robot --limit 10",
      "canonical": "cass search \"query\" --robot --limit 10",
      "accepted": true,
      "behavior": "Levenshtein command recovery corrects the top-level subcommand typo."
    },
    {
      "wrong": "cass -robot-help",
      "canonical": "cass --robot-help",
      "accepted": true,
      "behavior": "Single-dash long global flags are normalized to double-dash form."
    },
    {
      "wrong": "cass --Robot-help",
      "canonical": "cass --robot-help",
      "accepted": true,
      "behavior": "Long flags are lowercased when the lowercase spelling is known."
    },
    {
      "wrong": "cass --robot-docs=commands",
      "canonical": "cass robot-docs commands",
      "accepted": true,
      "behavior": "The legacy flag-shaped spelling is normalized into the robot-docs subcommand."
    },
    {
      "wrong": "cass commands --json",
      "canonical": "cass robot-docs commands",
      "accepted": true,
      "behavior": "Non-command robot-docs topic shorthands such as commands, schemas, examples, env, paths, exit-codes, and guide route to robot-docs instead of search."
    },
    {
      "wrong": "cass search \"query\" limit=5",
      "canonical": "cass search \"query\" --limit 5",
      "accepted": true,
      "behavior": "Bare key=value arguments are promoted to known long flags."
    },
    {
      "wrong": "cass robot-docs --robot",
      "canonical": "cass robot-docs guide",
      "accepted": true,
      "behavior": "robot-docs is already machine-readable; redundant robot/json flags are removed and the guide topic is used by default."
    },
    {
      "wrong": "cass help --json",
      "canonical": "cass robot-docs guide",
      "accepted": true,
      "behavior": "Structured help requests route to the agent guide instead of clap's human help path."
    },
    {
      "wrong": "cass help commands --json",
      "canonical": "cass robot-docs commands",
      "accepted": true,
      "behavior": "Structured help for robot-docs topics routes directly to the matching robot-docs topic."
    },
    {
      "wrong": "cass search --help --json",
      "canonical": "cass robot-docs commands",
      "accepted": true,
      "behavior": "Structured command help routes to the machine-readable command reference while plain --help remains native clap help."
    },
    {
      "wrong": "cass ready --json",
      "canonical": "cass triage --json",
      "accepted": true,
      "behavior": "ready is accepted as the one-shot agent triage alias."
    },
    {
      "wrong": "cass preflight --json",
      "canonical": "cass triage --json",
      "accepted": true,
      "behavior": "preflight is accepted as the one-shot agent triage alias."
    },
    {
      "wrong": "cass --json",
      "canonical": "cass triage --json",
      "accepted": true,
      "behavior": "A top-level structured-output request defaults to read-only agent triage instead of launching the TUI or failing usage."
    },
    {
      "wrong": "cass --robot",
      "canonical": "cass triage --json",
      "accepted": true,
      "behavior": "A top-level robot-mode request defaults to read-only agent triage."
    },
    {
      "wrong": "cass --json search auth",
      "canonical": "cass search auth --json",
      "accepted": true,
      "behavior": "A leading structured-output flag is moved after the robot-capable subcommand."
    },
    {
      "wrong": "cass --robot status",
      "canonical": "cass status --json",
      "accepted": true,
      "behavior": "A leading robot-mode flag is canonicalized to the subcommand's JSON output flag."
    },
    {
      "wrong": "cass --data-dir /tmp/cass health --json",
      "canonical": "cass health --data-dir /tmp/cass --json",
      "accepted": true,
      "behavior": "A leading data-dir override is moved onto the data-dir-aware subcommand."
    },
    {
