          "arg_type": "option",
          "value_type": "string",
          "required": false
        },
        {
          "name": "validate-config",
          "description": "Validate config file without running export",
          "arg_type": "flag",
          "required": false,
          "enum_values": [
            "true",
            "false"
          ]
        },
        {
          "name": "example-config",
          "description": "Show example config file",
          "arg_type": "flag",
          "required": false,
          "enum_values": [
            "true",
            "false"
          ]
        },
        {
          "name": "robot-format",
          "description": "Output format for robot mode (overrides --json when specified)",
          "arg_type": "option",
          "value_type": "enum",
          "required": false,
          "enum_values": [
            "json",
            "jsonl",
            "compact",
            "sessions",
            "toon"
          ]
        }
      ],
      "has_json_output": true
    },
    {
      "name": "quarantine",
      "description": "Inspect and manage the conversation-ingest quarantine (list / clear)",
      "arguments": [],
      "has_json_output": false
    },
    {
      "name": "forget",
      "description": "Prune an already-indexed subset of conversations by source-path glob (dry-run by default; `--apply` to commit). Removes matching rows from the canonical DB and rebuilds derived search/analytics assets",
      "arguments": [
        {
          "name": "source-glob",
          "description": "Glob over conversation `source_path` (e.g. `**/subagents/*.jsonl`)",
          "arg_type": "option",
          "value_type": "string",
          "required": true
        },
        {
          "name": "db",
          "description": "Override db path",
          "arg_type": "option",
          "value_type": "path",
          "required": false
        },
        {
          "name": "apply",
          "description": "Actually delete the matching conversations. Without this, runs as a dry-run (inspect only)",
          "arg_type": "flag",
          "required": false,
          "default": "false",
          "enum_values": [
            "true",
            "false"
          ]
        },
        {
          "name": "json",
          "description": "Output as JSON (`--robot` also works)",
          "arg_type": "flag",
          "required": false,
          "enum_values": [
            "true",
            "false"
          ]
        },
        {
          "name": "robot-format",
          "description": "Output format for robot mode (overrides --json when specified)",
          "arg_type": "option",
          "value_type": "enum",
          "required": false,
          "enum_values": [
            "json",
            "jsonl",
            "compact",
            "sessions",
            "toon"
          ]
        }
      ],
      "has_json_output": true
    },
    {
      "name": "mirror",
      "description": "Inspect and prune raw-mirror evidence under explicit operator control",
      "arguments": [],
      "has_json_output": false
    },
    {
      "name": "sources",
      "description": "Manage remote sources (P5.x)",
      "arguments": [],
      "has_json_output": false
    },
    {
      "name": "models",
      "description": "Manage semantic search models",
      "arguments": [],
      "has_json_output": false
    },
    {
      "name": "lessons",
      "description": "Mine and query durable lessons from local evidence (commits, beads, proofs)",
      "arguments": [],
      "has_json_output": false
    },
    {
      "name": "swarm",
      "description": "Read-only swarm operations status, work packets, and coordination lint",
      "arguments": [],
      "has_json_output": false
    },
    {
      "name": "import",
      "description": "Import data from external sources",
      "arguments": [],
      "has_json_output": false
    },
    {
      "name": "analytics",
      "description": "Token usage, tool, and model analytics",
      "arguments": [],
      "has_json_output": false
    },
    {
      "name": "release-verify",
      "description": "Verify release distribution channels (GitHub, Homebrew, Scoop, crates.io, installer)",
      "arguments": [
        {
          "name": "from",
          "description": "Read a ReleaseVerifyRequest JSON from a file (or `-` for stdin) and evaluate it offline. Mutually exclusive with --live",
          "arg_type": "option",
          "value_type": "path",
          "required": false
        },
        {
          "name": "live",
          "description": "Gather live per-channel observations over the network (explicit opt-in)",
          "arg_type": "flag",
          "required": false,
          "enum_values": [
            "true",
            "false"
          ]
        },
        {
          "name": "expected-version",
          "description": "Expected release version under test (required for --live)",
          "arg_type": "option",
          "value_type": "string",
          "required": false
        },
        {
          "name": "repo",
          "description": "GitHub owner/repo for the release channel (defaults to the cass repo)",
          "arg_type": "option",
          "value_type": "string",
          "required": false
        },
        {
          "name": "crate-name",
          "description": "crates.io crate name (defaults to the cass crate)",
          "arg_type": "option",
          "value_type": "string",
          "required": false
        },
        {
          "name": "homebrew-formula-url",
          "description": "Raw URL of the Homebrew formula file (enables the homebrew channel)",
          "arg_type": "option",
          "value_type": "string",
          "required": false
        },
        {
          "name": "scoop-manifest-url",
          "description": "Raw URL of the Scoop manifest JSON (enables the scoop channel)",
          "arg_type": "option",
          "value_type": "string",
          "required": false
        },
        {
          "name": "json",
          "description": "Output as JSON (`--robot` also works). Default for this command",
          "arg_type": "flag",
          "required": false,
          "enum_values": [
            "true",
            "false"
          ]
        },
        {
          "name": "robot-format",
          "description": "Output format for robot mode (overrides --json when specified)",
          "arg_type": "option",
          "value_type": "enum",
          "required": false,
          "enum_values": [
            "json",
            "jsonl",
            "compact",
            "sessions",
            "toon"
          ]
        }
      ],
      "has_json_output": true
    },
    {
      "name": "daemon",
      "description": "Run the semantic model daemon (Unix only)",
      "arguments": [
        {
          "name": "socket",
          "description": "Socket path to listen on (default comes from env or built-in config)",
          "arg_type": "option",
          "value_type": "path",
          "required": false
        },
        {
          "name": "idle-timeout",
          "description": "Idle timeout in seconds before auto-shutdown (0 = never; default comes from env or built-in config)",
          "arg_type": "option",
          "value_type": "string",
          "required": false
        },
        {
          "name": "max-connections",
          "description": "Maximum concurrent connections (default comes from env or built-in config)",
          "arg_type": "option",
          "value_type": "string",
          "required": false
        },
        {
          "name": "data-dir",
          "description": "Override data dir for model storage",
          "arg_type": "option",
          "value_type": "path",
          "required": false
        }
      ],
      "has_json_output": false
    }
  ],
