          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "doctor_command": {
          "type": "object",
          "additionalProperties": true
        },
        "doctor_v2_contract": {
          "type": "object",
          "description": "Schema-first doctor v2 contract inventory. Runtime commands may be implemented incrementally, but these response schema keys and branch fields are stable.",
          "properties": {
            "schema_version": {
              "type": "integer"
            },
            "response_schema_keys": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "examples": [
                [
                  "doctor-archive-normalize",
                  "doctor-archive-scan",
                  "doctor-backups-list",
                  "doctor-backups-verify",
                  "doctor-baseline-diff",
                  "doctor-baseline-save",
                  "doctor-baseline-update",
                  "doctor-check",
                  "doctor-cleanup-apply",
                  "doctor-cleanup-dry-run",
                  "doctor-error-envelope",
                  "doctor-failure-context",
                  "doctor-health-summary",
                  "doctor-reconstruct-dry-run",
                  "doctor-remote-source-sync-gaps",
                  "doctor-repair-dry-run",
                  "doctor-repair-receipt",
                  "doctor-restore-rehearsal",
                  "doctor-safe-auto-run",
                  "doctor-semantic-model-fallback",
                  "doctor-status-summary",
                  "doctor-support-bundle"
                ]
              ]
            },
            "common_branch_fields": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "examples": [
                [
                  "schema_version",
                  "surface",
                  "mode",
                  "status",
                  "outcome_kind",
                  "risk_level",
                  "asset_class",
                  "fallback_mode",
                  "authority_status",
                  "coverage_delta",
                  "blocked_reasons",
                  "plan_fingerprint",
                  "receipt_path",
                  "event_log_path",
                  "artifact_manifest_path",
                  "recommended_action",
                  "redaction_status",
                  "contract_provenance"
                ]
              ]
            },
            "branch_order": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "examples": [
                [
                  "err.kind",
                  "status",
                  "operation_outcome.kind",
                  "outcome_kind",
                  "asset_class",
                  "risk_level",
                  "fallback_mode"
                ]
              ]
            },
            "stdout_contract": {
              "type": "string"
            },
            "stderr_contract": {
              "type": "string"
            },
            "mutation_contract": {
              "type": "string"
            },
            "example_provenance": {
              "type": "string"
            }
          },
          "required": [
            "schema_version",
            "response_schema_keys",
            "common_branch_fields",
            "branch_order",
            "stdout_contract",
            "stderr_contract",
            "mutation_contract",
            "example_provenance"
          ],
          "examples": [
            {
              "schema_version": 2,
              "response_schema_keys": [
                "doctor-archive-normalize",
                "doctor-archive-scan",
                "doctor-backups-list",
                "doctor-backups-verify",
                "doctor-baseline-diff",
                "doctor-baseline-save",
                "doctor-baseline-update",
                "doctor-check",
                "doctor-cleanup-apply",
                "doctor-cleanup-dry-run",
                "doctor-error-envelope",
                "doctor-failure-context",
                "doctor-health-summary",
                "doctor-reconstruct-dry-run",
                "doctor-remote-source-sync-gaps",
                "doctor-repair-dry-run",
                "doctor-repair-receipt",
                "doctor-restore-rehearsal",
                "doctor-safe-auto-run",
                "doctor-semantic-model-fallback",
                "doctor-status-summary",
                "doctor-support-bundle"
              ],
              "common_branch_fields": [
                "schema_version",
                "surface",
                "mode",
                "status",
                "outcome_kind",
                "risk_level",
                "asset_class",
                "fallback_mode",
                "authority_status",
                "coverage_delta",
                "blocked_reasons",
                "plan_fingerprint",
                "receipt_path",
                "event_log_path",
                "artifact_manifest_path",
                "recommended_action",
                "redaction_status",
                "contract_provenance"
              ],
              "branch_order": [
                "err.kind",
                "status",
                "operation_outcome.kind",
                "outcome_kind",
                "asset_class",
                "risk_level",
                "fallback_mode"
              ],
              "stdout_contract": "robot stdout is parseable JSON only",
              "stderr_contract": "diagnostics, progress, and detailed logs use stderr or artifact paths",
              "mutation_contract": "mutating commands require a dry-run fingerprint or safe auto eligibility and never delete source evidence",
              "example_provenance": "contract-example"
            }
          ]
