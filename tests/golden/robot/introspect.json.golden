              "type": "boolean"
            },
            "safe_auto_run_eligible": {
              "type": "boolean"
            },
            "last_receipt_path": {
              "type": [
                "string",
                "null"
              ]
            },
            "failure_marker_path": {
              "type": [
                "string",
                "null"
              ]
            },
