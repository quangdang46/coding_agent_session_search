              "type": [
                "integer",
                "null"
              ]
            },
            "missing_current_source_count": {
              "type": [
                "integer",
                "null"
              ]
            },
            "conversation_delta": {
              "type": [
                "integer",
                "null"
              ]
            },
            "message_delta": {
              "type": [
                "integer",
                "null"
              ]
            },
