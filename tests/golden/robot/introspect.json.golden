          "required": false,
          "enum_values": [
            "true",
            "false"
          ]
        },
        {
          "name": "robot-format",
          "description": "Output format for robot mode (overrides --json when specified)",
          "arg_type": "option",
          "value_type": "enum",
          "required": false,
          "enum_values": [
            "json",
            "jsonl",
            "compact",
            "sessions",
            "toon"
          ]
        }
