        "doctor_summary": {
          "type": "object",
          "description": "Doctor summary block embedded by health/status so agents can decide whether doctor inspection is needed without running repair.",
          "properties": {
            "schema_version": {
              "type": "integer",
              "description": "Doctor v2 response schema version. Version 2 is the first schema-first contract for typed agents."
            },
            "surface": {
              "type": "string",
              "enum": [
                "legacy-doctor",
                "check",
                "repair",
                "cleanup",
                "reconstruct",
                "restore",
                "baseline",
                "baseline-diff",
                "support-bundle",
                "health-summary",
                "status-summary",
                "backups",
                "archive-scan",
                "archive-normalize",
                "semantic-model-fallback",
                "remote-source-sync-gaps",
                "failure-context",
                "error-envelope"
              ]
            },
            "mode": {
              "type": "string",
              "enum": [
                "read-only-check",
                "repair-dry-run",
                "fingerprint-apply",
                "safe-auto-fix",
                "cleanup-dry-run",
                "cleanup-apply",
                "reconstruct-dry-run",
                "restore-rehearsal",
                "support-bundle",
                "baseline-save",
                "baseline-update",
                "baseline-diff",
                "not-applicable"
              ]
            },
            "status": {
              "type": "string",
              "enum": [
                "ok",
                "warn",
                "planned",
                "applied",
                "partial",
                "blocked",
                "failed",
                "skipped",
                "saved",
                "updated",
                "changed",
                "unchanged"
              ]
            },
            "outcome_kind": {
              "type": "string",
              "enum": [
                "no_op",
                "planned",
                "applied",
                "partial",
                "blocked",
                "failed"
              ]
            },
            "risk_level": {
              "type": "string",
              "enum": [
                "none",
                "low",
                "medium",
                "high",
                "unknown"
              ]
            },
            "asset_class": {
              "type": "string",
              "description": "Stable snake_case DoctorAssetClass such as canonical_archive_db, raw_mirror_blob, derived_lexical_index, support_bundle, or external_upstream_source."
            },
            "fallback_mode": {
              "type": "string",
              "enum": [
                "none",
                "lexical",
                "semantic",
                "hybrid",
                "read-only",
                "unavailable",
                "not-applicable"
              ]
            },
            "authority_status": {
              "type": "string",
              "enum": [
                "read_only",
                "selected",
                "candidate_only",
                "promotable",
                "refused",
                "unavailable",
                "not_applicable"
              ]
            },
            "coverage_delta": {
              "type": "object",
              "description": "Counts-only coverage delta. It never contains raw session text.",
              "properties": {
                "status": {
                  "type": "string",
                  "enum": [
                    "unchanged",
                    "improved",
                    "reduced",
                    "unknown"
                  ]
                },
                "archive_conversation_count": {
                  "type": [
                    "integer",
                    "null"
                  ]
                },
                "visible_source_conversation_count": {
                  "type": [
                    "integer",
                    "null"
                  ]
                },
                "raw_mirror_manifest_count": {
                  "type": [
                    "integer",
                    "null"
                  ]
                },
                "db_projection_only_count": {
                  "type": [
                    "integer",
                    "null"
                  ]
                },
                "missing_current_source_count": {
                  "type": [
                    "integer",
                    "null"
                  ]
                },
                "conversation_delta": {
                  "type": [
                    "integer",
                    "null"
                  ]
                },
