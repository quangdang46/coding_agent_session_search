  "repair_contract": {
    "default_mode": "check",
    "default_non_destructive": true,
    "fail_closed": true,
    "plan_receipt_schema": {
      "plan_schema_version": 1,
      "receipt_schema_version": 1,
      "action_schema_version": 1,
      "artifact_schema_version": 1,
      "fingerprint_algorithm": "blake3-canonical-json-v1",
      "plan_fingerprint_includes": [
        "plan_kind",
        "schema_version",
        "mode",
        "approval_requirement",
        "approval_fingerprint",
        "outcome_contract",
        "coverage_before",
        "safety_gates",
        "actions",
        "artifact_manifest",
        "selected_authorities",
        "rejected_authorities",
        "blocked_reasons",
        "remaining_risk"
      ],
      "receipt_required_fields": [
        "receipt_kind",
        "schema_version",
        "mode",
        "outcome_kind",
        "approval_fingerprint",
        "plan_fingerprint",
        "started_at_ms",
        "finished_at_ms",
        "actions",
        "action_status_counts",
        "artifact_manifest",
        "drift_detection_status",
        "coverage_before",
        "coverage_after"
      ],
      "action_statuses": [
        "planned",
        "applied",
        "skipped",
        "blocked",
        "failed",
        "refused"
      ],
      "artifact_checksum_statuses": [
        "not_recorded",
        "matched",
        "mismatched",
        "missing"
      ],
      "drift_detection_statuses": [
        "not_checked",
        "verified",
        "checksum_mismatch",
        "missing_artifact",
        "manifest_mismatch"
      ],
      "redaction_contract": "robot receipts may expose existing doctor paths; support bundles must redact before export",
      "tamper_evidence_scope": "plan fingerprints, artifact manifests, event logs, and forensic bundles"
    },
    "verification_contract": {
      "schema_version": 1,
      "artifact_directory_contract": "each scripted doctor e2e run writes one durable artifact directory named <timestamp>-<scenario_id> with manifest.json at the root and one subdirectory per command step",
      "manifest_file": "manifest.json",
      "per_step_log_contract": "each step captures command/env metadata, stdout, stderr, parsed JSON, before/after inventories, checksums, receipts, timing, and redaction report paths",
      "required_manifest_fields": [
        "schema_version",
        "scenario_id",
        "command_line",
        "env",
        "binary_version",
        "started_at_ms",
        "finished_at_ms",
        "temp_data_dir_layout",
        "steps",
        "file_inventory_before",
        "file_inventory_after",
        "inventory_before",
        "inventory_after",
        "checksums",
        "receipts",
        "coverage_deltas",
        "redaction_report"
      ],
      "required_step_log_fields": [
        "step_id",
        "scenario_id",
        "command_line",
        "env",
        "exit_code",
        "stdout_path",
        "stderr_path",
        "parsed_json_path",
        "receipt_paths",
        "inventory_before_path",
        "inventory_after_path",
        "duration_ms",
        "redacted_paths"
      ],
      "required_inventory_fields": [
        "path",
        "redacted_path",
        "asset_class",
        "size_bytes",
        "mtime_ms",
        "descriptor_blake3",
        "content_blake3",
        "exists"
      ],
      "required_receipt_fields": [
        "receipt_kind",
        "schema_version",
        "mode",
        "outcome_kind",
        "approval_fingerprint",
        "plan_fingerprint",
        "started_at_ms",
        "finished_at_ms",
        "actions",
        "action_status_counts",
        "artifact_manifest",
        "drift_detection_status",
        "coverage_before",
        "coverage_after"
      ],
      "required_redaction_guarantees": [
        "raw session content is never copied into manifests by default",
        "support-bundle paths include redacted_path alongside exact local path fields",
        "environment captures must exclude secrets and token-shaped values",
        "stdout/stderr logs used for artifacts must be scrubbed before export"
      ],
      "matrix": [
        {
          "scenario_id": "no_delete_default_check",
          "feature_area": "default non-destructive doctor",
          "proof_layers": [
            "unit",
            "cli",
            "golden",
            "scripted_e2e"
          ],
          "representative_commands": [
            "cass doctor --json"
          ],
          "required_artifacts": [
            "manifest.json",
            "step-001/stdout.json",
            "step-001/stderr.txt",
            "step-001/inventory-before.json",
            "step-001/inventory-after.json"
          ],
          "mutation_audit_required": true,
          "redaction_required": true,
          "archive_preservation_assertion": "inventory_before and inventory_after must prove no archive, source, or user-state path was removed or rewritten",
          "notes": "This is the baseline guardrail: doctor with no repair mode is always read-only."
        },
        {
          "scenario_id": "upstream_pruned_archive_survives",
          "feature_area": "archive preservation after provider log pruning",
          "proof_layers": [
            "integration",
            "scripted_e2e"
          ],
          "representative_commands": [
            "cass index --full --json",
            "cass doctor --json",
            "cass search <known archived text> --json"
          ],
          "required_artifacts": [
            "manifest.json",
            "provider-inventory-before.json",
            "provider-inventory-after-prune.json",
            "cass-archive-query.json"
          ],
          "mutation_audit_required": true,
          "redaction_required": true,
          "archive_preservation_assertion": "cass archive DB remains queryable after upstream session files disappear",
          "notes": "Proves cass is a durable archive and not merely a live provider-log view."
        },
        {
          "scenario_id": "corrupt_db_repair_plan",
          "feature_area": "corruption diagnosis and repair planning",
          "proof_layers": [
            "unit",
            "fault_injection",
            "scripted_e2e"
          ],
          "representative_commands": [
            "cass doctor --json",
            "cass doctor --fix --json"
          ],
          "required_artifacts": [
            "manifest.json",
            "corrupt-db-before.bin",
            "doctor-plan.json",
            "doctor-receipt.json",
            "inventory-after.json"
          ],
          "mutation_audit_required": true,
          "redaction_required": true,
          "archive_preservation_assertion": "any corrupted archive bundle is backed up or quarantined before derived rebuild work proceeds",
          "notes": "Fault-injection proof must be diagnosable without rerunning against the user's real archive."
        },
        {
          "scenario_id": "stale_lock_and_active_rebuild",
          "feature_area": "lock ownership and interrupted operation handling",
          "proof_layers": [
            "unit",
            "integration",
            "scripted_e2e"
          ],
          "representative_commands": [
            "cass health --json",
            "cass doctor --json",
            "cass doctor --fix --json"
          ],
          "required_artifacts": [
            "manifest.json",
            "lock-state-before.json",
            "doctor-output.json",
            "lock-state-after.json"
          ],
          "mutation_audit_required": true,
          "redaction_required": true,
          "archive_preservation_assertion": "active rebuild locks block mutating cleanup and repairs; stale-lock handling records the owner and decision",
          "notes": "Prevents two doctor processes from racing repairs or cleanup."
        },
        {
          "scenario_id": "restore_rehearsal_then_apply",
          "feature_area": "backup verification and restore",
          "proof_layers": [
            "unit",
            "integration",
            "scripted_e2e"
          ],
          "representative_commands": [
            "cass doctor restore --dry-run --json",
            "cass doctor restore --apply --json"
          ],
          "required_artifacts": [
            "manifest.json",
            "restore-rehearsal-receipt.json",
            "restore-apply-receipt.json",
            "archive-query-after-restore.json"
          ],
          "mutation_audit_required": true,
          "redaction_required": true,
          "archive_preservation_assertion": "restore apply must require a rehearsal receipt and must verify archive readability after replacement",
          "notes": "Restore tests are intentionally separate from cleanup tests because they can touch canonical archive state."
        },
        {
          "scenario_id": "derived_cleanup_fingerprint_apply",
          "feature_area": "derived cleanup dry-run/apply",
          "proof_layers": [
            "unit",
            "cli",
            "golden",
            "scripted_e2e"
          ],
          "representative_commands": [
            "cass doctor --json",
            "cass doctor --fix --json",
            "cass diag --json --quarantine"
          ],
          "required_artifacts": [
            "manifest.json",
            "cleanup-plan.json",
            "cleanup-receipt.json",
            "inventory-before.json",
            "inventory-after.json"
          ],
          "mutation_audit_required": true,
          "redaction_required": true,
          "archive_preservation_assertion": "only derived reclaimable assets may disappear; source logs, archive DB, receipts, bundles, and quarantined evidence remain",
          "notes": "This scenario owns the before/after filesystem mutation audit contract."
        },
        {
          "scenario_id": "semantic_fallback_no_archive_damage",
          "feature_area": "semantic model and vector readiness",
          "proof_layers": [
            "unit",
            "integration",
            "golden"
          ],
          "representative_commands": [
            "cass models status --json",
            "cass health --json",
            "cass search <query> --json --robot-meta"
          ],
          "required_artifacts": [
            "manifest.json",
            "models-status.json",
            "health.json",
            "search-robot-meta.json"
          ],
          "mutation_audit_required": false,
          "redaction_required": true,
          "archive_preservation_assertion": "missing semantic assets report lexical fallback and never imply archive corruption",
          "notes": "Semantic fallback is readiness information, not a destructive repair path."
        },
        {
          "scenario_id": "multi_machine_source_sync_coverage",
          "feature_area": "source mirrors and multi-machine archive coverage",
          "proof_layers": [
            "integration",
            "scripted_e2e"
          ],
          "representative_commands": [
            "cass sources list --json",
            "cass sources sync --all --json",
            "cass doctor --json"
          ],
          "required_artifacts": [
            "manifest.json",
            "sources-before.json",
            "sync-output.json",
            "coverage-ledger-after.json",
            "doctor-output.json"
          ],
          "mutation_audit_required": true,
          "redaction_required": true,
          "archive_preservation_assertion": "source sync tests prove coverage ledgers update without deleting local archive evidence",
          "notes": "This keeps remote-source health distinct from local archive safety."
        }
      ]
    },
    "approval_requirements": [
      "none",
      "approval_fingerprint",
      "explicit_operator_confirmation",
      "rehearsal_receipt",
      "refused"
    ],
    "outcome_kinds": [
      "no_op",
      "planned",
      "applied",
      "partial",
      "blocked",
      "failed"
    ],
    "operation_outcome_kinds": [
      "ok-no-action-needed",
      "ok-read-only-diagnosed",
      "fixed",
      "partially-fixed",
      "repair-blocked",
      "repair-refused",
      "repair-incomplete",
      "verification-failed",
      "cleanup-dry-run-only",
      "cleanup-refused",
      "auto-run-skipped",
      "support-bundle-only",
      "baseline-diff-only",
      "requires-manual-review"
    ],
    "operation_outcome_contract": [
      {
        "kind": "ok-no-action-needed",
        "reason": "doctor found no work that needs action",
        "action_taken": "diagnostics completed",
        "action_not_taken": "no repair or cleanup was needed",
        "safe_to_retry": true,
        "requires_override": false,
        "data_loss_risk": "none",
        "next_command": null,
        "artifact_manifest_path": null,
        "exit_code_kind": "success"
      },
      {
        "kind": "ok-read-only-diagnosed",
        "reason": "doctor diagnosed issues without mutation",
        "action_taken": "read-only diagnostics completed",
        "action_not_taken": "repair was not attempted in read-only mode",
        "safe_to_retry": true,
        "requires_override": false,
        "data_loss_risk": "low",
        "next_command": "cass doctor --fix --json",
        "artifact_manifest_path": null,
        "exit_code_kind": "health-failure"
      },
      {
        "kind": "fixed",
        "reason": "requested operation completed all safe planned work",
        "action_taken": "safe repair or cleanup actions were applied",
        "action_not_taken": "no planned safe action was skipped",
        "safe_to_retry": true,
        "requires_override": false,
        "data_loss_risk": "none",
        "next_command": "cass doctor --json",
        "artifact_manifest_path": "receipt.artifact_manifest",
        "exit_code_kind": "success"
      },
      {
        "kind": "partially-fixed",
        "reason": "requested operation applied some work but left blocked work",
        "action_taken": "a subset of safe actions was applied",
        "action_not_taken": "blocked or skipped actions remain",
        "safe_to_retry": true,
        "requires_override": false,
        "data_loss_risk": "medium",
        "next_command": "cass doctor --json",
        "artifact_manifest_path": "receipt.artifact_manifest",
        "exit_code_kind": "repair-failure"
      },
      {
        "kind": "repair-blocked",
        "reason": "repair could not proceed because a required precondition was blocked",
        "action_taken": "no unsafe mutation was performed",
        "action_not_taken": "repair was not attempted until the blocker is resolved",
        "safe_to_retry": false,
        "requires_override": false,
        "data_loss_risk": "unknown",
        "next_command": "cass doctor --json",
        "artifact_manifest_path": null,
        "exit_code_kind": "lock-busy"
      },
      {
        "kind": "repair-refused",
        "reason": "repair request violated the doctor safety contract",
        "action_taken": "the unsafe request was refused",
        "action_not_taken": "no archive or source evidence was mutated",
        "safe_to_retry": false,
        "requires_override": true,
        "data_loss_risk": "high",
        "next_command": "cass doctor --json",
        "artifact_manifest_path": null,
        "exit_code_kind": "usage-error"
      },
      {
        "kind": "repair-incomplete",
        "reason": "repair started but did not reach a verified receipt",
        "action_taken": "available receipt or event-log evidence was preserved",
        "action_not_taken": "doctor did not claim successful repair",
        "safe_to_retry": false,
        "requires_override": false,
        "data_loss_risk": "medium",
        "next_command": "cass doctor --json",
        "artifact_manifest_path": "receipt.artifact_manifest",
        "exit_code_kind": "repair-failure"
      },
      {
        "kind": "verification-failed",
        "reason": "post-repair verification failed",
        "action_taken": "failure evidence was retained for inspection",
        "action_not_taken": "doctor refused to repeat repair automatically",
        "safe_to_retry": false,
        "requires_override": false,
        "data_loss_risk": "high",
        "next_command": "cass doctor --json",
        "artifact_manifest_path": "receipt.artifact_manifest",
        "exit_code_kind": "repair-failure"
      },
      {
        "kind": "cleanup-dry-run-only",
        "reason": "cleanup was planned without mutation",
        "action_taken": "cleanup candidates and approval fingerprint were reported",
        "action_not_taken": "no cleanup target was pruned",
        "safe_to_retry": true,
        "requires_override": false,
        "data_loss_risk": "none",
